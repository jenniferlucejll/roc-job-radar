{
  "name": "@roc-job-radar/backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx --env-file-if-exists=../../.env.development watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx --env-file-if-exists=../../.env.development src/db/migrate.ts",
    "db:verify-journal": "node scripts/check-migration-ledger.mjs",
    "db:seed": "tsx --env-file-if-exists=../../.env.development src/db/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@roc-job-radar/ai-agent": "file:../ai-agent",
    "cheerio": "^1.0.0",
    "drizzle-orm": "^0.36.4",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.1",
    "node-cron": "^3.0.3",
    "playwright-core": "^1.58.2",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "@types/node-cron": "^3.0.11",
    "drizzle-kit": "^0.27.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
