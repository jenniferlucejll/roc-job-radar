# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=roc_job_radar
POSTGRES_USER=rjr
POSTGRES_PASSWORD=<replace-me>

# Server
SERVER_HOST=127.0.0.1
PORT=3000
NODE_ENV=development

# Scraper
SCRAPE_CRON=0 8 * * *
SCRAPE_TIMEOUT_MS=30000
SCRAPE_MAX_RETRY_ATTEMPTS=3
SCRAPE_RETRY_BASE_DELAY_MS=1000
SCRAPE_REQUEST_INTERVAL_MS=1000
SCRAPE_DETAIL_INTERVAL_MS=3000
USER_AGENT=roc-job-radar/1.0 (personal job monitoring tool)

# AI Agent (Ollama)
AI_ENABLED=false
OLLAMA_API_URL=http://127.0.0.1:11434/api/chat
OLLAMA_MODEL=gemma3
AI_REQ_TIMEOUT_MS=60000
AI_MAX_CHARS=12000
AI_REQUEST_MAX_TOKENS=768
AI_MAX_PARALLELISM=3
AI_MAX_RETRIES=1
AI_RETRY_BASE_DELAY_MS=500
